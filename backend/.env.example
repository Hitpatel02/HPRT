# HPRT Backend — Environment Variable Reference
# Copy this file to .env and fill in real values before deploying.
# NEVER commit .env to version control.

# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgres://<user>:<password>@<host>:<port>/<database>
PGUSER=postgres
PGPASSWORD=<your_db_password>
PGHOST=localhost
PGPORT=5432
PGDATABASE=HPFP

# ── JWT ───────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=<64-byte-hex-secret>

# ── Microsoft Graph API (Outlook Email) ──────────────────────────────────
TENANT_ID=<azure-tenant-id>
CLIENT_ID=<azure-client-id>
CLIENT_SECRET=<azure-client-secret>
SENDER_EMAIL=office@yourdomain.com

# ── Server ────────────────────────────────────────────────────────────────
PORT=8080
# Set to 'production' on VPS
NODE_ENV=production
# LOG_LEVEL default = info. Use 'debug' for verbose output.
LOG_LEVEL=info

# ── CORS (Security) ───────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Leave empty or unset to allow all origins (development only).
# Example: CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com
CORS_ORIGIN=

# ── Feature Flags ─────────────────────────────────────────────────────────
DISABLE_EMAIL_SERVICE=false
DISABLE_WHATSAPP_SERVICE=false

# ── WhatsApp / Puppeteer ──────────────────────────────────────────────────
# Required on Linux VPS if Chrome is not in the default PATH.
# Example: PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome-stable
PUPPETEER_EXECUTABLE_PATH=
