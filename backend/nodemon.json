{
  "watch": [
    "config/*.js",
    "controllers/*.js",
    "middleware/*.js",
    "middlewares/*.js",
    "routes/*.js",
    "services/*.js",
    "queries/*.js",
    "jobs/*.js",
    "utils/*.js",
    "*.js"
  ],
  "ignore": [
    "whatsapp-session/**",
    ".wwebjs_auth/**",
    ".wwebjs_cache/**",
    "../whatsapp-data/**",
    "node_modules/**",
    "logs/**",
    "tmp/**",
    ".git/**",
    "*.log",
    ".env",
    "package-lock.json"
  ],
  "delay": 1000,
  "verbose": false,
  "ext": "js,json"
}